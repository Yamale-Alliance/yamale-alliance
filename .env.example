# Clerk Authentication - https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Basic HTTP Authentication (for staging/demo)
# Set ENABLE_BASIC_AUTH=true to enable password protection
ENABLE_BASIC_AUTH=false
BASIC_AUTH_USERNAME=yamale
BASIC_AUTH_PASSWORD=demo2024

# Supabase - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL for emails, share links, and /robots.txt `host`. In production .env: add uncommented, e.g. NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NEXT_PUBLIC_APP_URL=https://yamale-alliance.vercel.app

# AI crawler block is ON by default (no env needed). Only set BLOCK_AI_SCRAPER_UA=false when debugging locally with a spoofed crawler User-Agent — do not set in production.
# BLOCK_AI_SCRAPER_UA=false

# Support centre (tickets + Resend). Off until you have a verified sending domain.
# NEXT_PUBLIC_SUPPORT_CENTER_ENABLED=1
# Support emails (Resend — https://resend.com). Create API key + verified sending domain.
# RESEND_API_KEY=re_...
# From address must use your verified domain, e.g. Yamalé <support@yourdomain.com>
# EMAIL_FROM=Yamalé <support@yourdomain.com>
# Inbox where new tickets & user replies are notified (team distribution list recommended)
# SUPPORT_INBOX_EMAIL=support@yourdomain.com



# Lomi (hosted checkout for cards & regional wallets)
# Setup guide: https://docs.lomi.africa/reference/setup/integration
# Dashboard: https://lomi.africa — Developers → API (secret keys) and webhooks.
#
# LOMI_API_KEY — secret key only on the server (never NEXT_PUBLIC_*). Prefix must match environment:
#   live  → lomi_sk_live_…   → https://api.lomi.africa
#   test  → lomi_sk_test_…   → https://sandbox.api.lomi.africa
# The @lomi./sdk sends this as X-API-Key on each request (same as the doc curl).
LOMI_API_KEY=
# live | production | prod  → live API.  test | sandbox  → sandbox API (must use lomi_sk_test_… key).
LOMI_ENVIRONMENT=live
# Optional host override without trailing slash (…/v1 suffix is stripped). Defaults match the doc hosts above.
# LOMI_API_BASE_URL=https://api.lomi.africa
# Smoke test (same as Lomi docs): curl -sS -H "X-API-Key: $LOMI_API_KEY" "https://api.lomi.africa/accounts"
#
# Webhook: https://docs.lomi.africa/reference/payments/webhooks — register HTTPS URL in Lomi (POST /webhooks or dashboard).
# Subscribe to events you need (e.g. PAYMENT_SUCCEEDED). Store the returned signing secret here (often `whsec_…`).
# Verify header `X-Lomi-Signature` = HMAC-SHA256(raw body, secret). Lomi does not send `X-API-Key` on delivery.
# Example URL: https://your-domain.com/api/lomi/webhook
LOMI_WEBHOOK_SECRET=
# Show “Card & wallets” in the UI (recommended). Alternatively set NEXT_PUBLIC_LOMI_PUBLISHABLE_KEY.
NEXT_PUBLIC_LOMI_CHECKOUT_ENABLED=1
# Optional — required only if you embed Lomi Payment Elements on the client later
# NEXT_PUBLIC_LOMI_PUBLISHABLE_KEY=lomi_pk_...

# --- AI Legal Research (POST /api/ai/chat) ---
# Injects a cached title index from `laws` (Title | Country | Category | Status) into the system prompt for coverage/disambiguation.
# AI_LAW_TITLE_CATALOG_DISABLED=1
# Optional cap on catalog characters (default 72000). Raise only if your model context allows it.
# AI_LAW_TITLE_CATALOG_MAX_CHARS=72000

# Claude AI - https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-...
# Optional: override model (defaults use claude-haiku-4-5; retired ids like claude-3-5-haiku-20241022 return 404). List: GET https://api.anthropic.com/v1/models
# CLAUDE_MODEL=claude-sonnet-4-6
# Used for admin “law from PDF URL” import and Admin → Laws → Fix OCR (AI) batch cleanup (heuristics if unset for import).

# Optional contextual web snippets for AI Legal Research (Tavily). Runs only on heuristics (e.g. time-sensitive or explicit web-style asks). The key is sent as JSON `api_key` and as `Authorization: Bearer` per Tavily. If the fetch fails or returns no rows, a short "miss" block is still injected so the model explains the technical limit instead of denying internet access. `webSearchNote` on the chat JSON summarizes what happened. Yamalé library excerpts remain primary for binding law. Disable with AI_WEB_SEARCH_DISABLED=1.
# TAVILY_API_KEY=tvly-...
# AI_WEB_SEARCH_DISABLED=1

# Cloudinary - https://cloudinary.com (for logo/favicon uploads in admin branding)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# --- Library law PDF (pay-per-law export) ---
# Purchases are written to Supabase `pay_as_you_go_purchases` (item_type = document) after payment
# (webhook and/or POST /api/library/confirm-document-payment). Admin → Library PDF purchases lists them.
# Use the SAME Supabase project (and Clerk app) in local `.env` as on Vercel so localhost and production
# show the same rows in admin and on /library/purchased.

# pawaPay (mobile money) — https://pawapay.io
# Required for the pawaPay payment path: subscriptions, marketplace (pawaPay), lawyer unlocks,
# lawyer search unlock, day pass, pay-as-you-go AI/document/AfCFTA, team extra seats, etc.
# Get your API token from the pawapay merchant dashboard (sandbox vs production).
PAWAPAY_API_TOKEN=
# API base URL (default below is sandbox). Use production host when you go live.
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
# Currency for Payment Page amounts (ISO 4217), e.g. USD, EUR, XAF
PAWAPAY_CURRENCY=USD
# Optional USD -> local currency conversion rate for pawaPay pricing.
# Required when PAWAPAY_CURRENCY is not USD. Example: 130 for KES.
# PAWAPAY_USD_EXCHANGE_RATE=
# Optional per-currency conversion overrides (recommended for multi-country setup):
# PAWAPAY_USD_EXCHANGE_RATE_KES=130
# PAWAPAY_USD_EXCHANGE_RATE_RWF=1300
# PAWAPAY_USD_EXCHANGE_RATE_UGX=3800
# PAWAPAY_USD_EXCHANGE_RATE_XOF=600
# PAWAPAY_USD_EXCHANGE_RATE_XAF=600
# PAWAPAY_USD_EXCHANGE_RATE_ZMW=27
# PAWAPAY_USD_EXCHANGE_RATE_CDF=2800
# PAWAPAY_USD_EXCHANGE_RATE_SLE=23
# Legacy: checkout flows use the user's selected mobile money country in the app, not this env var.
# PAWAPAY_COUNTRY=
# Optional customer message fallback (4-22 chars, letters/numbers/spaces only)
# PAWAPAY_CUSTOMER_MESSAGE=Yamale Payment
# Optional: public base URL for pawaPay Payment Page returnUrl (scheme + host, no path).
# Sandbox: if checkout Origin is https (Vercel, ngrok), that origin is used. http://localhost is
# rejected by pawaPay as returnUrl — set this to an https URL (e.g. Vercel or ngrok) so checkout works;
# after payment you land here unless you open the app via an https tunnel to localhost.
# Live: prefers https Origin; otherwise this when https (e.g. ngrok for local dev against live API).
# PAWAPAY_RETURN_BASE_URL=https://yamale-alliance.vercel.app
# Subscription prices: set in Admin → Pricing (`pricing_plans` in Supabase), not via env.
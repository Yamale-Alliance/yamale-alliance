# Clerk Authentication - https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Basic HTTP Authentication (for staging/demo)
# Set ENABLE_BASIC_AUTH=true to enable password protection
ENABLE_BASIC_AUTH=false
BASIC_AUTH_USERNAME=yamale
BASIC_AUTH_PASSWORD=demo2024

# Supabase - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key



# Stripe - https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create Products/Prices in Stripe Dashboard, then set Price IDs here:
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_DAY_PASS=price_...

# Claude AI - https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-...
# Optional: override model (defaults use claude-haiku-4-5; retired ids like claude-3-5-haiku-20241022 return 404). List: GET https://api.anthropic.com/v1/models
# CLAUDE_MODEL=claude-sonnet-4-6
# Used for admin “law from PDF URL” import and Admin → Laws → Fix OCR (AI) batch cleanup (heuristics if unset for import).

# Cloudinary - https://cloudinary.com (for logo/favicon uploads in admin branding)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# pawaPay (mobile money) — https://pawapay.io
# Required for the pawaPay payment path: subscriptions, marketplace (pawaPay), lawyer unlocks,
# lawyer search unlock, day pass, pay-as-you-go AI/document/AfCFTA, team extra seats, etc.
# Get your API token from the pawapay merchant dashboard (sandbox vs production).
PAWAPAY_API_TOKEN=
# API base URL (default below is sandbox). Use production host when you go live.
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
# Currency for Payment Page amounts (ISO 4217), e.g. USD, EUR, XAF
PAWAPAY_CURRENCY=USD
# Optional USD -> local currency conversion rate for pawaPay pricing.
# Required when PAWAPAY_CURRENCY is not USD. Example: 130 for KES.
# PAWAPAY_USD_EXCHANGE_RATE=
# Optional per-currency conversion overrides (recommended for multi-country setup):
# PAWAPAY_USD_EXCHANGE_RATE_KES=130
# PAWAPAY_USD_EXCHANGE_RATE_RWF=1300
# PAWAPAY_USD_EXCHANGE_RATE_UGX=3800
# PAWAPAY_USD_EXCHANGE_RATE_XOF=600
# PAWAPAY_USD_EXCHANGE_RATE_XAF=600
# PAWAPAY_USD_EXCHANGE_RATE_ZMW=27
# PAWAPAY_USD_EXCHANGE_RATE_CDF=2800
# PAWAPAY_USD_EXCHANGE_RATE_SLE=23
# Required for fixed-amount payment page requests: ISO 3166-1 alpha-3 country code (e.g. RWA, GHA, KEN)
PAWAPAY_COUNTRY=
# Optional customer message fallback (4-22 chars, letters/numbers/spaces only)
# PAWAPAY_CUSTOMER_MESSAGE=Yamale Payment
# Public HTTPS base URL used for pawaPay returnUrl (recommended for live mode)
# PAWAPAY_RETURN_BASE_URL=https://yamale-alliance.vercel.app
# Subscription plan prices in cents (used by POST /api/stripe/checkout when using pawaPay).
# Set the ones you sell; omit or zero to disable a plan/interval.
# PAWAPAY_PLAN_BASIC_MONTHLY_CENTS=
# PAWAPAY_PLAN_BASIC_ANNUAL_CENTS=
# PAWAPAY_PLAN_PRO_MONTHLY_CENTS=
# PAWAPAY_PLAN_PRO_ANNUAL_CENTS=
# PAWAPAY_PLAN_TEAM_MONTHLY_CENTS=
# PAWAPAY_PLAN_TEAM_ANNUAL_CENTS=
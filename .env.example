# Clerk Authentication - https://dashboard.clerk.com
#
# LOCAL DEV: use pk_test_… / sk_test_… from the *Development* instance in .env.local only.
#   pk_live_* fails on localhost with "Production Keys are only allowed for domain yamalelegal.com".
#
# PRODUCTION (Vercel): use pk_live_… / sk_live_… from the *Production* instance.
#   Add https://www.yamalelegal.com and https://yamalelegal.com under Clerk → Domains.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Optional: only after Clerk custom domain DNS is VERIFIED (clerk.yamalelegal.com must resolve — see docs/CLERK_PRODUCTION.md)
# If DNS is missing, Clerk JS fails with failed_to_load_clerk_js.
# NEXT_PUBLIC_CLERK_FRONTEND_API=clerk.yamalelegal.com
# Auth page paths — must match real routes: /sign-in and /signup (not /sign-up unless you add a redirect)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
# Redirects after auth (Clerk v6 — prefer these over deprecated AFTER_SIGN_* vars)
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/api/auth/complete-signup?role=user
# Do not set SIGN_UP_FORCE_REDIRECT_URL=/dashboard — it skips /api/auth/complete-signup role setup

# Basic HTTP Authentication (for staging/demo)
# Set ENABLE_BASIC_AUTH=true to enable password protection
ENABLE_BASIC_AUTH=false
BASIC_AUTH_USERNAME=yamale
BASIC_AUTH_PASSWORD=demo2024

# Supabase - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres URI for maintenance scripts (embeddings:backfill-fts)
# Project Settings → Database → Connection string → URI (pooler port 6543)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# App URL for emails, share links, and /robots.txt `host`. In production .env: add uncommented.
# Production site URL (used in emails, robots.txt, and Clerk CSP for www.yamalelegal.com)
NEXT_PUBLIC_APP_URL=https://www.yamalelegal.com

# Redeploy bump (comment-only; safe to update when Vercel Git webhooks miss a push): 2026-06-16

# --- Google Analytics (GA4) — gtag.js in root layout; omit locally to skip third-party scripts ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-EYJ2HD6H9Q

# --- Error monitoring (Sentry) — see docs/MONITORING.md ---
# NEXT_PUBLIC_SENTRY_DSN=https://…@….ingest.sentry.io/…
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=yamale-alliance
# SENTRY_AUTH_TOKEN=sntrys_…
# SENTRY_ENABLE_IN_DEV=true  # optional; off by default so local `next dev` skips heavy Sentry/OTel bundles

# AI crawler block is ON by default (no env needed). Only set BLOCK_AI_SCRAPER_UA=false when debugging locally with a spoofed crawler User-Agent — do not set in production.
# BLOCK_AI_SCRAPER_UA=false

# Golden-question batch eval (npm run eval:golden) — see docs/AI_GOLDEN_EVAL.md
# openssl rand -hex 32
# AI_EVAL_SECRET=
# AI_EVAL_CLERK_USER_ID=user_…   # Team/Pro account; not counted against plan/daily caps when using Bearer secret
# AI_EVAL_BASE_URL=http://localhost:3000
# AI_EVAL_DELAY_MS=2000           # pause between questions (rate limits / cost)

# k6 load tests (see docs/LOAD_TESTING.md) — pass BASE_URL when running npm run loadtest:*
# BASE_URL=https://your-app.vercel.app
# BASIC_AUTH_USERNAME=yamale         # required for loadtest:smoke if ENABLE_BASIC_AUTH=true
# BASIC_AUTH_PASSWORD=demo2024
# AI_EVAL_SECRET=…                # required only for npm run loadtest:ai

# Support centre (tickets + Resend). Off until you have a verified sending domain.
# NEXT_PUBLIC_SUPPORT_CENTER_ENABLED=1
# Support emails (Resend — https://resend.com). Create API key + verified sending domain.
# RESEND_API_KEY=re_...
# From address must use your verified domain, e.g. Yamalé <support@yourdomain.com>
# EMAIL_FROM=Yamalé <support@yourdomain.com>
# Inbox where new tickets & user replies are notified (team distribution list recommended)
# SUPPORT_INBOX_EMAIL=support@yourdomain.com
# AI Contextual Brain — folder of PDF/DOCX to ingest (npm run ingest:ai-context)
# Folder of PDF/DOCX for npm run ingest:ai-context (brain modules + deep dives)
# AI_CONTEXT_SOURCE_DIR=/Users/you/Documents/brain

# Law flags (library) notify this inbox via Resend when users report outdated text, UI issues, etc.



# Lomi (hosted checkout for cards & regional wallets)
# Setup guide: https://docs.lomi.africa/reference/setup/integration
# Dashboard: https://lomi.africa — Developers → API (secret keys) and webhooks.
#
# LOMI_API_KEY — secret key only on the server (never NEXT_PUBLIC_*). Prefix must match environment:
#   live  → lomi_sk_live_…   → https://api.lomi.africa
#   test  → lomi_sk_test_…   → https://sandbox.api.lomi.africa
# The @lomi./sdk sends this as X-API-Key on each request (same as the doc curl).
LOMI_API_KEY=
# live | production | prod  → live API.  test | sandbox  → sandbox API (must use lomi_sk_test_… key).
LOMI_ENVIRONMENT=live
# Optional host override without trailing slash (…/v1 suffix is stripped). Defaults match the doc hosts above.
# LOMI_API_BASE_URL=https://api.lomi.africa
# Smoke test (same as Lomi docs): curl -sS -H "X-API-Key: $LOMI_API_KEY" "https://api.lomi.africa/accounts"
#
# Webhook: https://docs.lomi.africa/reference/payments/webhooks — register HTTPS URL in Lomi (POST /webhooks or dashboard).
# Subscribe to events you need (e.g. PAYMENT_SUCCEEDED). Store the returned signing secret here (often `whsec_…`).
# Verify header `X-Lomi-Signature` = HMAC-SHA256(raw body, secret). Lomi does not send `X-API-Key` on delivery.
# Example URL: https://your-domain.com/api/lomi/webhook
LOMI_WEBHOOK_SECRET=
# Show “Card & wallets” in the UI (recommended). Alternatively set NEXT_PUBLIC_LOMI_PUBLISHABLE_KEY.
NEXT_PUBLIC_LOMI_CHECKOUT_ENABLED=1
# Optional — required only if you embed Lomi Payment Elements on the client later
# NEXT_PUBLIC_LOMI_PUBLISHABLE_KEY=lomi_pk_...
#
# Recurring subscription catalog (Lomi dashboard → Products → recurring tier → copy each price_id).
# Create Yamalé Basic / Pro / Team with monthly + annual prices; amounts must match Admin → Pricing.
# Used for subscription checkout (product_id optional; price_id is enough per Lomi checkout API).
# https://docs.lomi.africa/reference/payments/checkout-sessions
LOMI_PRICE_BASIC_MONTHLY=
LOMI_PRICE_BASIC_ANNUAL=
LOMI_PRICE_PRO_MONTHLY=
LOMI_PRICE_PRO_ANNUAL=
LOMI_PRICE_TEAM_MONTHLY=
LOMI_PRICE_TEAM_ANNUAL=
# One-time / PAYG (Lomi dashboard → one-time products)
LOMI_PRICE_DAY_PASS=
LOMI_PRICE_PAYG_DOCUMENT=
LOMI_PRICE_PAYG_AI_QUERY=
LOMI_PRICE_PAYG_AFCFTA_REPORT=
LOMI_PRICE_PAYG_LAWYER_SEARCH=
LOMI_PRICE_LAWYER_UNLOCK=          # optional; can equal lawyer search
LOMI_PRICE_TEAM_EXTRA_SEAT=        # per seat; use quantity at checkout



# --- AI Legal Research (POST /api/ai/chat) ---
# Claude timeout cap (seconds). Route segment maxDuration is 300 on Pro; this caps Claude abort below that.
# Default 60 (normal) / 300 (AI_RESEARCH_FULL_LIBRARY=1). Set 300 in production for long streams.
# AI_CHAT_MAX_DURATION_SEC=300
# Cap streamed answer length (default detailed mode 4096 tokens; was 4800). Lower = faster, shorter answers.
# AI_CHAT_MAX_OUTPUT_TOKENS=4096
# Methodology brain excerpts per doc (prod default 4500 chars; dev 6000). Fewer chars = faster Claude TTFT.
# AI_METHODOLOGY_MAX_CHARS_PER_DOC=4500
# AI_METHODOLOGY_MAX_DOCS=2
# Claude connection/TTFB abort (ms), capped below maxDuration minus AI_CHAT_DURATION_BUFFER_MS (default 8000).
# AI_CLAUDE_TIMEOUT_MS=90000
# AI_CHAT_DURATION_BUFFER_MS=8000
# Server timing in Vercel logs — filter `[PERF]` (default on; set AI_PERF_LOG=0 to disable).
# Disable in production per security audit: AI_PERF_LOG=0
# AI_PERF_LOG=0
# Emergency kill switch — when true, POST /api/ai/chat returns 503 immediately.
# AI_CHAT_DISABLED=false
# Production fails closed when the safety classifier cannot verify a request.
# Emergency override only: set true to allow fail-open behavior during a classifier outage.
# AI_SAFETY_CLASSIFIER_FAIL_OPEN=false
# App-level TOTP is required for admin + legal_admin panel access by default.
# Set ADMIN_MFA_DISABLED=true only for local dev without an authenticator.
# ADMIN_MFA_DISABLED=false
# Legacy flag (superseded): ADMIN_MFA_ENFORCED=true
# ADMIN_MFA_ENFORCED=true
# 32+ char secret for signing admin_mfa_step_up cookie (generate: openssl rand -base64 48)
# ADMIN_MFA_SECRET=
# 32+ char key for encrypting TOTP secrets at rest (generate: openssl rand -hex 32)
# ADMIN_MFA_ENCRYPTION_KEY=
# Step-up session TTL in seconds (default 43200 = 12 hours)
# ADMIN_MFA_SESSION_TTL_SEC=43200
# Set to true for local `next start` over HTTP (production NODE_ENV disables non-secure cookies otherwise)
# ADMIN_MFA_COOKIE_INSECURE=false
# Vercel KV / Upstash Redis for distributed rate limits (tier hourly quotas + API limits).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Or Vercel KV integration aliases:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# VirusTotal API v3 (https://www.virustotal.com/gui/join-us)
# PDF/ZIP document scanning is OFF by default (too slow for large law PDFs).
# Set VIRUSTOTAL_SCAN_FILES=1 to re-enable scanFile() for documents. Admin image uploads still use hash lookup.
# VIRUSTOTAL_API_KEY=
# VIRUSTOTAL_SCAN_FILES=0
# Max wait for new-file analysis (ms, default 120000). Hash-known files return instantly.
# VIRUSTOTAL_MAX_POLL_MS=120000
# Production fails closed when scans cannot complete. In development, set this to true to mirror prod timeout behavior.
# VIRUSTOTAL_FAIL_ON_TIMEOUT=false
# Emergency override only: allow uploads when VirusTotal is missing/unavailable in production.
# VIRUSTOTAL_ALLOW_UNSCANNED_UPLOADS=false
# RAG body size (default: full-instrument review for country-scoped legal Q&A; prompt budget trims if needed).
# Unset prod ≈ 320k total / 120k top-2 primary acts / 48k supporting; dev similar. Lower only for cost tests.
# AI_RAG_MAX_CONTEXT_CHARS=220000
# AI_RAG_MULTI_DOC_CAP=320000
# AI_RAG_FULL_REVIEW_TOTAL_CHARS=320000
# AI_RAG_FULL_REVIEW_PRIMARY_PER_DOC_CHARS=120000
# AI_RAG_FULL_REVIEW_SECONDARY_PER_DOC_CHARS=48000
# AI_RAG_QUICK_FALLBACK_CHARS=24000
# AI_RAG_MAX_DOC_SLOTS=16
# AI_RAG_MAX_SYSTEM_DOCS=16
# AI_RAG_MAX_SYSTEM_DOCS_DETAILED=18
# Tax/labour/IP focused turns (dev defaults 32k/11k; prod ~24k/9k when unset):
# AI_RAG_PRIMARY_STATUTE_TOTAL_CHARS=120000
# AI_RAG_PRIMARY_STATUTE_PER_DOC_CHARS=45000
# AI_RAG_NAMED_STATUTE_TOTAL_CHARS=180000
# When retrieval returns fewer docs, widen with quick fallback up to this count (0 disables).
# AI_RAG_SOURCING_FLOOR=8
# Auto-flag laws when the assistant reports excerpt/library gaps (admin → AI quality → Corpus gaps). Set 0 to disable.
# AI_AUTO_QUALITY_FLAGS=1
# Hard cap on Claude input (system + history) to avoid 200k context errors (Q148-style).
# AI_MAX_INPUT_TOKENS_EST=175000
# AI_MAX_SYSTEM_PROMPT_CHARS=620000
# --- AI cost / abuse caps (enforced before Claude; see docs/AI_ABUSE_CAPS.md) ---
# Per-user message & conversation limits (prod defaults lower when unset).
# AI_CHAT_MAX_USER_MESSAGE_CHARS=8000
# AI_CHAT_MAX_MESSAGES=28
# AI_CHAT_MAX_TOTAL_CONVERSATION_CHARS=64000
# AI_CHAT_MAX_ATTACHMENTS=2
# AI_CHAT_MAX_ATTACHMENT_BASE64_CHARS=600000
# Hard daily cap per user (UTC day), reserved in DB before Claude. 0 or "unlimited" disables.
# AI_DAILY_QUERY_CAP_FREE=3
# AI_DAILY_QUERY_CAP_BASIC=15
# AI_DAILY_QUERY_CAP_PRO=50
# AI_DAILY_QUERY_CAP_TEAM=40
# Team org shared pool (billing admin + members on team tier).
# AI_TEAM_DAILY_QUERY_CAP=150
# Block identical prompts within window (needs Upstash; falls back to in-memory on single instance).
# AI_DUPLICATE_PROMPT_WINDOW_SEC=60
# Skip title catalog when country is known and the question is statute-focused (faster pre-stream).
# AI_LAW_TITLE_CATALOG_ALWAYS=1
# Tavily timeout ms when web search runs in parallel with RAG (default 4500).
# AI_WEB_SEARCH_TIMEOUT_MS=4500
# AI_WEB_SEARCH_DISABLED=1
# Full-library mode (default OFF): loads every in-scope law body per turn — slow; use only if needed.
# AI_RESEARCH_FULL_LIBRARY=1
# AI_FULL_LIBRARY_MAX_LAWS=50000
# Unset defaults are now ~1.2–1.5M total / 100–120k per law (not 48M). Override only if needed:
# AI_FULL_LIBRARY_MAX_INPUT_CHARS=1500000
# AI_FULL_LIBRARY_MAX_CHARS_PER_LAW=120000
# Safer full-library for one country (example — tune to your model/context):
# AI_RESEARCH_FULL_LIBRARY=1
# AI_FULL_LIBRARY_MAX_LAWS=400
# Injects a cached title index from `laws` (Title | Country | Category | Status) into the system prompt for coverage/disambiguation.
# AI_LAW_TITLE_CATALOG_DISABLED=1
# Optional cap on catalog characters (default 24k when a country is scoped, 72k global; 2M when full-library mode is on).
# AI_LAW_TITLE_CATALOG_MAX_CHARS=24000

# Claude AI - https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-...
# Hybrid vector RAG (optional): run docs/sql/law-embeddings-pgvector.sql then npm run embeddings:backfill
# VOYAGE_API_KEY=pa-...          # recommended — voyage-law-2 (1024 dims, legal-tuned)
# OPENAI_API_KEY=sk-...          # alternative — text-embedding-3-small (requires SQL dims 1536; use voyage for default migration)
# AI_EMBEDDING_MODEL=voyage-law-2
# AI_EMBEDDINGS_ENABLED=1        # set 0 to disable vector pass even when keys exist
# Chunk-level hybrid retrieval (run docs/sql/law-embeddings-hybrid-retrieval.sql first)
# RETRIEVAL_MODE=vector          # vector (default) | hybrid — FTS+pgvector RRF
# RETRIEVAL_TOP_CHUNKS=40          # RRF-ranked chunks for generation context (max 100)
# RETRIEVAL_LAW_RESOLVE_THRESHOLD=0.4   # scope chunk search when resolve_law score >= this
# RETRIEVAL_MIN_CHUNKS=3                # absence guard: min chunks for high confidence
# RETRIEVAL_MIN_TOP_RRF=0.012           # absence guard: min top RRF score
# RETRIEVAL_ABSENCE_GUARD_ENABLED=1     # set 0 to skip resolve_law fallback + not_found_log
# AI_QUERY_UNDERSTANDING_ENABLED=1
# AI_QUERY_UNDERSTANDING_MODEL=claude-haiku-4-5-20251001
# Optional: override model (defaults use claude-haiku-4-5; retired ids like claude-3-5-haiku-20241022 return 404). List: GET https://api.anthropic.com/v1/models
# CLAUDE_MODEL=claude-sonnet-4-6
# Used for admin “law from PDF URL” import and Admin → Laws → Fix OCR (AI) batch cleanup (heuristics if unset for import).

# Cloud OCR for scanned law PDFs on hosts without pdftoppm/tesseract (e.g. Vercel).
# Uses CLAUDE_API_KEY + pdfjs page renders. Disable with LAW_CLOUD_OCR_DISABLED=1.
# LAW_CLOUD_OCR_MODEL=claude-haiku-4-5
# LAW_CLOUD_OCR_MAX_PAGES=40
# LAW_CLOUD_OCR_SCALE=1.75
# LAW_CLOUD_OCR_DELAY_MS=400
# LAW_CLOUD_OCR_DISABLED=0

# Optional contextual web snippets for AI Legal Research (Tavily). Runs only on heuristics (e.g. time-sensitive or explicit web-style asks). The key is sent as JSON `api_key` and as `Authorization: Bearer` per Tavily. If the fetch fails or returns no rows, a short "miss" block is still injected so the model explains the technical limit instead of denying internet access. `webSearchNote` on the chat JSON summarizes what happened. Yamalé library excerpts remain primary for binding law. Disable with AI_WEB_SEARCH_DISABLED=1.
# TAVILY_API_KEY=tvly-...
# AI_WEB_SEARCH_DISABLED=1

# Cloudinary - https://cloudinary.com (required for Vault product cover uploads; branding, lawyer photos)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# --- Library law PDF (pay-per-law export) ---
# Purchases are written to Supabase `pay_as_you_go_purchases` (item_type = document) after payment
# (webhook and/or POST /api/library/confirm-document-payment). Admin → Library PDF purchases lists them.
# Use the SAME Supabase project (and Clerk app) in local `.env` as on Vercel so localhost and production
# show the same rows in admin and on /library/purchased.

# pawaPay (mobile money) — https://pawapay.io
# Required for the pawaPay payment path: subscriptions, marketplace (pawaPay), lawyer unlocks,
# lawyer search unlock, day pass, pay-as-you-go AI/document/AfCFTA, team extra seats, etc.
# Get your API token from the pawapay merchant dashboard (sandbox vs production).
# --- Checkout currency (Lomi) ---
CHECKOUT_CURRENCY=USD
# Required when CHECKOUT_CURRENCY is not USD. Example: 130 for KES.
# CHECKOUT_USD_EXCHANGE_RATE=
# CHECKOUT_USD_EXCHANGE_RATE_KES=130

# --- Vercel Cron (payment reconciliation every 15 min — see vercel.json) ---
# Generate: openssl rand -hex 32
# CRON_SECRET=
# Manual run: curl -sS -H "Authorization: Bearer $CRON_SECRET" https://your-domain/api/cron/payment-reconciliation

# --- Distributed rate limiting (production on Vercel — required for accurate limits) ---
# Create a free Redis database: https://console.upstash.com → Vercel integration copies these automatically.
# Without these, API limits use per-server memory only (too loose on multi-instance deploys).
# UPSTASH_REDIS_REST_URL=https://….upstash.io
# UPSTASH_REDIS_REST_TOKEN=…